# Copy this file to .env on the server and fill values there.
# Never commit real Toss Securities credentials.

# OAuth 2.0 Client Credentials Grant fields from Toss Open API docs:
# POST /oauth2/token form body requires grant_type=client_credentials,
# client_id, and client_secret. grant_type is fixed in code.
TOSSINVEST_CLIENT_ID=
TOSSINVEST_CLIENT_SECRET=

# Default is paper. Live order submission also requires --execute and
# --i-understand-real-order on the CLI.
TOSSINVEST_TRADING_MODE=paper

# Toss Open API base server from llms.txt/OpenAPI docs.
TOSSINVEST_BASE_URL=https://openapi.tossinvest.com
